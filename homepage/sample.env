#####################################################################
# Core container settings
#####################################################################

# Docker container name
CONTAINER_NAME=homepage

# Host timezone
TZ=America/Denver

#####################################################################
# User and group mapping
#####################################################################

# Numeric user ID that should own config files
PUID=1000

# Numeric group ID that should own config files
PGID=1000

#####################################################################
# Storage
#####################################################################

# Root storage path on the host
# This directory must exist:
# $VOLUMEROOT/${CONTAINER_NAME}/config
VOLUMEROOT=/mnt/storage

#####################################################################
# Networking
#####################################################################

# Name of an existing external Docker network
# Must already exist:
# docker network create net_internal
INTERNAL_NETWORK=net_internal

#####################################################################
# Homepage runtime configuration
#####################################################################

# Comma separated list of allowed hosts
# Use your FQDN and internal hostname
# Example:
# HOMEPAGE_ALLOWED_HOSTS=homepage.local,homepage.example.com
HOMEPAGE_ALLOWED_HOSTS=homepage.local

#####################################################################
# Optional Homepage Docker self integration labels
# These are not required by Homepage itself.
# They are useful if:
# 1) You want reverse proxy automation
# 2) You want another Homepage instance to auto discover this one
#####################################################################

HOMEPAGE_SERVICE_GROUP=Infrastructure
HOMEPAGE_SERVICE_NAME=Homepage
HOMEPAGE_URL=http://homepage:3000
HOMEPAGE_DESCRIPTION=Application dashboard
HOMEPAGE_USERNAME=admin
HOMEPAGE_PASSWORD=change_me
