#####################################################################
# Core container settings
#####################################################################

# Container name shown in Docker
CONTAINER_NAME=filebrowser

# Host timezone, example: America/Denver
TZ=America/Denver

# Host port to expose Filebrowser on (host:container 80)
WEBPORT=8080

#####################################################################
# User and group IDs
#####################################################################

# Numeric user ID on the host that should own created files
# Common value on many systems is 1000
UUID=1000

# Numeric group ID on the host that should own created files
# Common value on many systems is 1000
GUID=1000

#####################################################################
# Storage paths
#####################################################################

# Root path on the host for persistent data and browsable files
# Example for a dedicated dataset:
# VOLUMEROOT=/mnt/storage
VOLUMEROOT=/mnt/storage

# Notes on what the compose does with VOLUMEROOT:
# 1) Mounts ${VOLUMEROOT} to /srv (everything under VOLUMEROOT is browsable)
# 2) Persists database under ${VOLUMEROOT}/${CONTAINER_NAME}/database
# 3) Persists config under ${VOLUMEROOT}/${CONTAINER_NAME}/config

#####################################################################
# Networking
#####################################################################

# Name of an existing external Docker network to attach this service to
# This network must already exist: docker network create <name>
INTERNAL_NETWORK=net_internal

#####################################################################
# Homepage integration labels
#####################################################################

# Group and service name as shown in Homepage
HOMEPAGE_SERVICE_GROUP=Storage
HOMEPAGE_SERVICE_NAME=Filebrowser

# URL that Homepage should link to and that the widget should query
# If Homepage is on the same Docker network, prefer internal addressing:
# HOMEPAGE_URL=http://filebrowser:80
# If using a reverse proxy or public DNS:
# HOMEPAGE_URL=https://files.example.com
HOMEPAGE_URL=http://filebrowser:80

# Description text in Homepage
HOMEPAGE_DESCRIPTION=Web file manager

# Widget credentials for Homepage to query Filebrowser
# Use a Filebrowser user that has permission to access the UI.
HOMEPAGE_USERNAME=admin
HOMEPAGE_PASSWORD=change_me
