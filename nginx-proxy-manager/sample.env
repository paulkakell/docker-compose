#####################################################################
# Core container settings
#####################################################################

# Docker container name
CONTAINER_NAME=nginx-proxy-manager

# Host timezone
TZ=America/Denver

#####################################################################
# Admin UI exposure
#####################################################################

# Host port that maps to NPM admin UI (container port 81)
# Choose a non-conflicting port, example 81, 8081, 8181
ADMIN_WEB_PORT=81

#####################################################################
# Storage
#####################################################################

# Root storage path on the host for NPM persistent data
# Must contain:
# ${VOLUME_ROOT}/${CONTAINER_NAME}/data
# ${VOLUME_ROOT}/${CONTAINER_NAME}/letsencrypt
VOLUME_ROOT=/mnt/storage

#####################################################################
# Networking
#####################################################################

# Name of an existing external Docker network used for public facing traffic
# Must already exist: docker network create <name>
EXTERNAL_NETWORK=net_external

# Name of an existing external Docker network used for internal app traffic
# Must already exist: docker network create <name>
INTERNAL_NETWORK=net_internal

#####################################################################
# Homepage integration labels
#####################################################################

# Group and service name as shown in Homepage
HOMEPAGE_SERVICE_GROUP=Infrastructure
HOMEPAGE_SERVICE_NAME=Nginx Proxy Manager

# URL Homepage should link to when clicking the service
# If you access the admin UI via LAN:
# HOMEPAGE_URL=http://your-lan-ip:${ADMIN_WEB_PORT}
# If you access via a DNS name:
# HOMEPAGE_URL=https://npm.example.com
HOMEPAGE_URL=http://your-lan-ip:81

# Short description shown in Homepage
HOMEPAGE_DESCRIPTION=Reverse proxy and certificate manager

# Docker server name used by Homepage docker integration
# Common values depend on your Homepage docker settings.
# If you did not customize, use "docker".
DOCKERSERVER=docker

# Widget credentials for the npm widget in Homepage
# Use an NPM admin user
HOMEPAGE_USERNAME=admin@example.com
HOMEPAGE_PASSWORD=change_me
